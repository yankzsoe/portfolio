<section class="dark" id="home">
    @if (hero is not null)
    {
        <img class="background" src="@(hero.Src)" alt="@(hero.Alt)" />
    }
    <div class="hero-content">
    @if (property is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <h1>@property.Name</h1>
        <h2>@property.Title</h2>
        <div class="hero-actions" aria-label="Primary links">
            <a class="button primary" href="#portfolio" target="_top">View Work</a>
            <a class="button secondary" href="#contact" target="_top">Contact</a>
        </div>
    }
    </div>
    <div class="scroll-cue">
        <a href="#about" target="_top" aria-label="Scroll to about section">
            <img src="images/down-arrow.svg" alt="" />
        </a>
    </div>
</section>

@code {
    [Parameter, EditorRequired]
    public required HttpClient Http { get; set; }

    [Parameter, EditorRequired]
    public required HeroImageService HeroImageService { get; set; }

    private SiteProperties? property;
    private HeroImage? hero;

    protected override async Task OnInitializedAsync()
    {
        property = await Http.GetFromJsonAsync<SiteProperties>("sample-data/siteproperties.json");
        hero = await HeroImageService.GetHeroAsync(img => img.Name is "home");
    }
}
